    #const MIN_PREDATOR_DISTANCE 30
    #const MAX_PREDATOR_DISTANCE 33
  percent_chance 33
    #const MIN_PREDATOR_DISTANCE 34
    #const MAX_PREDATOR_DISTANCE 37
