  <LAND_GENERATION>
  base_terrain BASE_FOREST
  enable_waves 0

  #FOR($i, 1, 3)
    create_land {
      terrain_type BASE$i
      land_position X$i Y$i
      assign_to AT_TEAM -10 0 0
      zone $i
      other_zone_avoidance_distance 8
      clumping_factor 5
      land_percent 22
      base_size 14
    }

    if ONE_POND_1V1
      /* Pond */
      create_land {
        terrain_type MED_WATER
        zone $i
        land_position POND_X$i POND_Y$i
        number_of_tiles 0
        base_size 5
      }
    endif
  #END_FOR

  /* Map Middle */
  create_land {
    terrain_type MIDDLE_PLACEHOLDER
    land_position X_PERP_0 Y_PERP_0
    number_of_tiles 0
    base_size 1
    zone 10
    other_zone_avoidance_distance 0
    land_id 10
  }

