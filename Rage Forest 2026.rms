<PLAYER_SETUP>
random_placement

/* Sets resource 203 to 1, enabling vision of the explored map. */
effect_amount MOD_RESOURCE CIRCUMNAVIGATION_RESOURCE ATTR_SET 1

/* Disables the abiliy to re-garrison Fishing Ships within Docks. */
effect_amount MUL_ATTRIBUTE DOCK ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE DOCK_F ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE DOCK_C ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE DOCK_I ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE HARBOR ATTR_GARRISON_CAPACITY 0

/* Disables the ability of Docks to shoot. */
effect_amount SET_ATTRIBUTE DOCK ATTR_PROJECTILE2_ID -1
effect_amount SET_ATTRIBUTE DOCK_F ATTR_PROJECTILE2_ID -1
effect_amount SET_ATTRIBUTE DOCK_C ATTR_PROJECTILE2_ID -1
effect_amount SET_ATTRIBUTE DOCK_I ATTR_PROJECTILE2_ID -1

effect_amount SET_ATTRIBUTE DOCK ATTR_SHOWN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_F ATTR_SHOWN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_C ATTR_SHOWN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_I ATTR_SHOWN_RANGE 0

effect_amount SET_ATTRIBUTE DOCK ATTR_MIN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_F ATTR_MIN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_C ATTR_MIN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_I ATTR_MIN_RANGE 0

effect_amount SET_ATTRIBUTE DOCK ATTR_MAX_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_F ATTR_MAX_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_C ATTR_MAX_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_I ATTR_MAX_RANGE 0

/*
 * Disables the ability of Fishing Ships to add artows to Docks.
 * In particular, this prevents Fishing Ships that are trained and
 * garrisoned immediately within Harbors from adding additional arrows
 * to the Harbors.
 */
effect_amount SET_ATTRIBUTE FISHING_SHIP ATTR_GARRISON_FIREPOWER 0
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER 0
effect_amount SET_ATTRIBUTE WHALING_SHIP ATTR_GARRISON_FIREPOWER 0

/* TODO predators */

<LAND_GENERATION>
base_terrain WATER
create_player_lands {
  terrain_type GRASS
  number_of_tiles 0
  base_size 10
}

<OBJECTS_GENERATION>
create_object TOWN_CENTER {
  set_place_for_every_player
  max_distance_to_players 0
}
