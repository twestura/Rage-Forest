/* Choose seasons for theming. */
if STANDARD_1V1
  start_random
    percent_chance 10 #define AFRICAN_THEME
    percent_chance 30 #define AUTUMN_THEME
    percent_chance 40 #define GRASS_THEME
    percent_chance 20 #define SNOW_THEME
  end_random
elseif STANDARD_2V2
  start_random
    percent_chance 35 #define GRASS_MAP
    percent_chance 20 #define AUTUMN_MAP
    percent_chance 15 #define SNOW_AUTUMN_MAP
    percent_chance 20 #define FROZEN_MAP
    percent_chance 10 #define JUNGLE_MAP
  end_random
else
  /* Choose seasons for 3v3, 4v4, and nonstandard maps. */
  start_random
    percent_chance 10 #define PH_AFRICAN_E
    percent_chance 15 #define PH_SPRING
    percent_chance 15 #define PH_ALPINE
    percent_chance 10 #define PH_TROPHICALSOUTH
    percent_chance 10 #define PH_TROPHICALEAST
    percent_chance 10 #define PH_AUTUMN
    percent_chance 15 #define PH_FROZEN
    percent_chance 15 #define PH_TROPHICALSOUTH_B
  end_random
endif

