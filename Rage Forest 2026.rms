<PLAYER_SETUP>
if STANDARD_1V1
  direct_placement
elseif STANDARD_2V2
  direct_placement
else
  random_placement
endif
ai_info_map_type BLACK_FOREST 0 0 0
behavior_version 2

/* Sets resource 203 to 1, enabling vision of the explored map. */
effect_amount MOD_RESOURCE CIRCUMNAVIGATION_RESOURCE ATTR_SET 1

/* Disables the abiliy to re-garrison Fishing Ships within Docks. */
effect_amount MUL_ATTRIBUTE DOCK ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE DOCK_F ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE DOCK_C ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE DOCK_I ATTR_GARRISON_CAPACITY 0
effect_amount MUL_ATTRIBUTE HARBOR ATTR_GARRISON_CAPACITY 0

/* Disables the ability of Docks to shoot. */
effect_amount SET_ATTRIBUTE DOCK ATTR_PROJECTILE2_ID -1
effect_amount SET_ATTRIBUTE DOCK_F ATTR_PROJECTILE2_ID -1
effect_amount SET_ATTRIBUTE DOCK_C ATTR_PROJECTILE2_ID -1
effect_amount SET_ATTRIBUTE DOCK_I ATTR_PROJECTILE2_ID -1

effect_amount SET_ATTRIBUTE DOCK ATTR_SHOWN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_F ATTR_SHOWN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_C ATTR_SHOWN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_I ATTR_SHOWN_RANGE 0

effect_amount SET_ATTRIBUTE DOCK ATTR_MIN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_F ATTR_MIN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_C ATTR_MIN_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_I ATTR_MIN_RANGE 0

effect_amount SET_ATTRIBUTE DOCK ATTR_MAX_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_F ATTR_MAX_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_C ATTR_MAX_RANGE 0
effect_amount SET_ATTRIBUTE DOCK_I ATTR_MAX_RANGE 0

/*
 * Disables the ability of Fishing Ships to add artows to Docks.
 * In particular, this prevents Fishing Ships that are trained and
 * garrisoned immediately within Harbors from adding additional arrows
 * to the Harbors.
 */
effect_amount SET_ATTRIBUTE FISHING_SHIP ATTR_GARRISON_FIREPOWER 0
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER 0
effect_amount SET_ATTRIBUTE WHALING_SHIP ATTR_GARRISON_FIREPOWER 0

/* Update predator attributes. */
/* Makes bears have the same size as Wolves */
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_RADIUS_1 PREDATOR_RADIUS
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_RADIUS_2 PREDATOR_RADIUS
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_RADIUS_1 PREDATOR_RADIUS
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_RADIUS_2 PREDATOR_RADIUS

/* Updates the predator graphics. */
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_NAME_ID PREDATOR_A_NAME_ID
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_ICON_ID PREDATOR_A_ICON_ID
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_DEAD_ID PREDATOR_A_DEAD_ID
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_ATTACK_GRAPHIC PREDATOR_A_ATTACK
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_ATTACK2_GRAPHIC PREDATOR_A_ATTACK2
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_STANDING_GRAPHIC PREDATOR_A_STANDING
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_DYING_GRAPHIC PREDATOR_A_DYING
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_UNDEAD_GRAPHIC PREDATOR_A_UNDEAD
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_WALKING_GRAPHIC PREDATOR_A_WALKING
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_A ATTR_RUNNING_GRAPHIC PREDATOR_A_RUNNING

effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_NAME_ID PREDATOR_B_NAME_ID
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_ICON_ID PREDATOR_B_ICON_ID
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_DEAD_ID PREDATOR_B_DEAD_ID
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_ATTACK_GRAPHIC PREDATOR_B_ATTACK
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_ATTACK2_GRAPHIC PREDATOR_B_ATTACK2
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_STANDING_GRAPHIC PREDATOR_B_STANDING
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_DYING_GRAPHIC PREDATOR_B_DYING
effect_amount GAIA_SET_ATTRIBUTE PREDATOR_B ATTR_UNDEAD_GRAPHIC PREDATOR_B_UNDEAD
