/* Constants for standard 1v1s. */
/* Determines the number of ponds per player. */
start_random
  percent_chance 50 #define NO_PONDS_1V1
  percent_chance 50 #define ONE_POND_1V1
end_random

/* Chooses the positions of the player ponds. */
/* #define FRONT_POND */
/* #define SIDE_POND */
/* #define BACK_POND */
start_random
  percent_chance 60 #define FRONT_POND
  percent_chance 40 #define SIDE_POND
end_random

/* Locations of the player lands. */
#const T1 rnd(0,359)
#const OFFSET rnd(155,205)
#const T2 (T1 + OFFSET)
#const R 28
#const R_POND 18
#FOR($i, 1, 3)
  #TRIG(T$i)
  #const X$i (R * COS_T$i + 50)
  #const Y$i (R * SIN_T$i + 50)

  start_random
    percent_chance 50 #define FLIP_POND$i
  end_random
  if FRONT_POND
    #const POND_OFFSET$i rnd(100,110)
  elseif SIDE_POND
    #const POND_OFFSET$i rnd(65,100)
  elseif BACK_POND
    #const POND_OFFSET$i rnd(0,65)
  else
    #const POND_OFFSET$i rnd(0,359)
  endif
  if FLIP_POND$i
    #const POND_T$i (POND_OFFSET$i * -1 + T$i)
  elseif
    #const POND_T$i (POND_OFFSET$i + T$i)
  endif
  #TRIG(POND_T$i)
  #const POND_X$i (R_POND * COS_POND_T$i + X$i)
  #const POND_Y$i (R_POND * SIN_POND_T$i + Y$i)
#END_FOR

/* Locations of the connection midpoint. */
