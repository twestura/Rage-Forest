      terrain_cost SECONDARY_FOREST 2
      terrain_cost BORDER_FOREST 2
      terrain_cost MIDDLE_PLACEHOLDER 1
      terrain_cost POCKET_TERRAIN 2
      terrain_cost CONNECTION_TERRAIN 2
      terrain_cost PATCH_TERRAIN 2

      terrain_size BASE_TERRAIN 5 1
      terrain_size BASE_FOREST 5 1
      terrain_size SECONDARY_FOREST 5 1
      terrain_size BORDER_FOREST 5 1
      terrain_size POCKET_TERRAIN 5 1
      terrain_size CONNECTION_TERRAIN 5 1
      terrain_size PATCH_TERRAIN 5 1
    }
  #END_FOR

