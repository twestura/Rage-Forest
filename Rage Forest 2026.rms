 * - 486 DLC_BEAR (Brown Bear): 0.4/0.4/0.4
 * - 2089 BLACK_BEAR (Black Bear): 0.34/0.34/0.34
 * - 2090 POLAR_BEAR (Polar Bear): 0.4/0.4/0.4
 */
