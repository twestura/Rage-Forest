    terrain_cost    MED_WATER 0
    terrain_cost    ICE       0
    terrain_cost    WOODIES   7
    terrain_cost    LAYER_A   2
    terrain_cost    LAYER_B   2
    terrain_cost    BEACH     0
    terrain_cost    CESTA     1
    terrain_cost BLOCKING_MIDDLE_FOREST 0
